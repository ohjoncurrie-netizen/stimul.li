# Copy to .env in production and replace every placeholder.

APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
GHCR_IMAGE=ghcr.io/your-github-org-or-user/stimuli-api:latest

# FastAPI / app secrets
SECRET_KEY=replace_with_a_long_random_secret
OPENAI_API_KEY=replace_with_openai_api_key

# PostgreSQL
DATABASE_URL=postgresql+psycopg://stimuli:replace_with_strong_password@postgres:5432/stimuli
POSTGRES_DB=stimuli
POSTGRES_USER=stimuli
POSTGRES_PASSWORD=replace_with_strong_password

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe
STRIPE_API_KEY=replace_with_stripe_secret_key
STRIPE_MONTHLY_PRICE_ID=price_replace_me
STRIPE_FLASH_METER_EVENT_NAME=flash_api_call

# Domain / callback config
API_BASE_URL=https://api.stimu.li
STRIPE_SUCCESS_URL=https://stimu.li/billing/success
STRIPE_CANCEL_URL=https://stimu.li/billing/cancel
